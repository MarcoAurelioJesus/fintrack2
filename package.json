{
  "name": "fintrack",
  "version": "1.0.0",
  "description": "FinTrack - Financial Management Application",
  "scripts": {
    "ng": "npx ng",
    "prestart": "npx kill-port 3000 4200",
    "start": "concurrently \"npm run start:api\" \"npm run start:proxy\"",
    "start:proxy": "npx ng serve --proxy-config proxy.conf.json",
    "start:api": "npm --prefix backend run dev",
    "seed:demo": "npm --prefix backend run seed:demo",
    "build": "npx ng build",
    "build:prod": "npx ng build --configuration production",
    "watch": "npx ng build --watch --configuration development",
    "test:unit": "vitest run",
    "test:all": "npm run test:unit && npm --prefix backend run test",
    "test": "npx ng test",
    "lint": "npx ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@primeuix/utils": "^0.6.4",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primeng": "^20.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.0",
    "vitest": "^2.1.8"
  }
}
